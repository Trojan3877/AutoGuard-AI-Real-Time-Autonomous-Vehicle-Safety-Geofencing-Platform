# ─────────────────────────────────────────────────────────────────────────────
# AutoGuard AI – Environment Variables Template
# Copy this file to .env and fill in real values before running locally.
#   cp .env.example .env
# .env is already in .gitignore and will NOT be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Maps (geofencing) ──────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_maps_api_key_here

# ── Snowflake (data pipeline) ─────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=AUTOGUARD
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── FastAPI / gRPC ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
GRPC_PORT=50051
LOG_LEVEL=INFO

# ── Dashboard ────────────────────────────────────────────────────────────────
# URL the Streamlit dashboard uses to reach the API service.
# Override to http://api:8000 when running via docker-compose.
API_BASE_URL=http://localhost:8000

# ── OpenTelemetry (tracing) ───────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=autoguard-api

# ── NVIDIA CUDA (GPU inference) ───────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
